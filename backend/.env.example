# ══════════════════════════════════════════════════════════════
# NeuraNotes Backend — Environment Variables
# Copy this file to .env and fill in your values
# All services below have FREE tiers — no credit card needed
# ══════════════════════════════════════════════════════════════

# ── App Settings ────────────────────────────────────────────
APP_ENV=development
APP_NAME=NeuraNotes
SECRET_KEY=change-me-to-a-random-32-char-string-use-openssl-rand
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,exp://192.168.1.100:8081

# ── Supabase (PostgreSQL + Auth + Storage + pgvector) ───────
# Get from: supabase.com → Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ── Upstash Redis (Rate Limiting + Cache) ───────────────────
# Get from: upstash.com → Create Database → Redis
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ── AI: Groq API (Llama 3.3 70B + GPT-OSS 120B + Whisper) ──
# Get from: console.groq.com → API Keys → Create API Key
# FREE: 12K req/day (70B), 8K req/day (120B), 2K audio/day
GROQ_API_KEY=gsk_your-groq-api-key

# ── AI: Google AI Studio (Embeddings) ──────────────────────
# Get from: aistudio.google.com → Get API Key
# Using gemini-embedding-001 (3072-dim, free tier)
GOOGLE_AI_API_KEY=your-google-ai-api-key

# ── AI Provider Switch ─────────────────────────────────────
# Options: "groq" (free) or "claude" (paid, better quality)
AI_PROVIDER=groq

# ── AI: Anthropic (Optional — paid upgrade) ────────────────
# Uncomment when ready to upgrade from Groq to Claude
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ── AI Observability: Langfuse ─────────────────────────────
# Get from: cloud.langfuse.com → New Project
# FREE: 50K observations/month
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Google OAuth (for user login) ──────────────────────────
# Get from: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# ── JWT Settings ───────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
